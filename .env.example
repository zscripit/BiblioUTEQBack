# Copia este archivo como .env en la raíz de BiblioUTEQBack y completa los secretos.
# Todos los microservicios comparten la conexión; cada entidad define su esquema (identidad,
# operaciones o catalogo) en su propia configuración/anotaciones.
BIBLIO_DB_URL=jdbc:postgresql://aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
BIBLIO_DB_USERNAME=postgres.tu-project-ref
BIBLIO_DB_PASSWORD=REEMPLAZAR_CON_LA_CONTRASENA_DE_SUPABASE
BIBLIO_DB_POOL_SIZE=5
BIBLIO_DB_MIN_IDLE=1
JPA_SHOW_SQL=false

# Comunicación OAuth 2.1 entre microservicios (usa secretos distintos y seguros en producción).
MS_NOTIFICATIONS_CLIENT_SECRET=REEMPLAZAR
MS_PRESTAMOS_CLIENT_SECRET=REEMPLAZAR

# SMTP de Gmail. Genera MAIL_PASSWORD como contraseña de aplicación de 16 caracteres.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-cuenta@gmail.com
MAIL_PASSWORD=REEMPLAZAR_CON_APP_PASSWORD_DE_GMAIL
MAIL_FROM=tu-cuenta@gmail.com
NOTIFICATIONS_MAX_ATTEMPTS=3
